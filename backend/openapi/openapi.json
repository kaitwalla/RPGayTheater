      },
      "ParticipantSessionResponse": { "type": "object", "required": ["data"], "properties": { "data": { "$ref": "#/components/schemas/ParticipantSession" } } },
      "ParticipantJoinResponse": { "type": "object", "required": ["data"], "properties": { "data": { "allOf": [{ "$ref": "#/components/schemas/ParticipantSession" }, { "type": "object", "required": ["resume_token"], "properties": { "resume_token": { "type": "string", "minLength": 64, "maxLength": 64 } } }] } } },
      "ParticipantRosterResponse": { "type": "object", "required": ["data"], "properties": { "data": { "type": "object", "required": ["role", "characters"], "properties": { "role": { "type": "string", "enum": ["player", "spectator"] }, "characters": { "type": "array", "items": { "$ref": "#/components/schemas/ParticipantCharacter" } } } } } },
      "ParticipantPlayerGroupsResponse": { "type": "object", "required": ["data"], "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/ParticipantPlayerGroup" } } } },
      "ParticipantMessagesResponse": { "type": "object", "required": ["data"], "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/ParticipantMessage" } } } },
      "ParticipantMessageMutationResponse": { "type": "object", "required": ["data", "meta"], "properties": { "data": { "$ref": "#/components/schemas/ParticipantMessage" }, "meta": { "$ref": "#/components/schemas/MutationMeta" } } },
      "ParticipantPollsResponse": { "type": "object", "required": ["data"], "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/ParticipantPoll" } } } },
