{
  "openapi": "3.1.0",
  "info": {
    "title": "RPGays Orchestration API",
    "version": "v1",
    "description": "Same-origin HTTP contract. Realtime events are invalidation hints only."
  },
  "paths": {
    "/api/control/v1/auth": {
      "get": {
        "operationId": "controlAuthenticationStatus",
        "responses": {
          "200": {
            "description": "Current Control session status.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ControlAuthenticationResponse" } } }
          }
        }
      }
    },
    "/api/control/v1/auth/login": {
      "post": {
        "operationId": "controlLogin",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ControlLoginRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Authenticated Control session.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ControlAuthenticationResponse" } } }
          },
          "422": { "description": "Invalid secret or request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "503": { "description": "Control authentication is unavailable.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/control/v1/auth/logout": {
      "post": {
        "operationId": "controlLogout",
        "responses": { "204": { "description": "Control session ended." }, "401": { "description": "Unauthenticated.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } } }
      }
    },
    "/api/control/v1/auth/confirm-secret": {
      "post": {
        "operationId": "confirmControlSecret",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ControlLoginRequest" } } }
        },
        "responses": {
          "200": {
            "description": "The Control secret was confirmed for high-risk changes.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ControlSecretConfirmationResponse" } } }
          },
          "401": { "description": "Unauthenticated.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "422": { "description": "Invalid secret or request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ControlAuthenticationResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["authenticated"],
            "properties": { "authenticated": { "type": "boolean" } }
          }
        }
      },
      "ControlLoginRequest": {
        "type": "object",
        "required": ["secret"],
        "properties": { "secret": { "type": "string", "minLength": 1, "maxLength": 4096 } }
      },
      "ControlSecretConfirmationResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["confirmed_until"],
            "properties": { "confirmed_until": { "type": "string", "format": "date-time" } }
          }
        }
      },
      "Error": {
        "type": "object",
        "required": ["message"],
        "properties": { "message": { "type": "string" }, "errors": { "type": "object", "additionalProperties": true } }
      }
    }
  }
}
