{
  "openapi": "3.1.0",
  "info": {
    "title": "RPGays Orchestration API",
    "version": "v1",
    "description": "Same-origin HTTP contract. Realtime events are invalidation hints only."
  },
  "paths": {
    "/api/control/v1/auth": {
      "get": {
        "operationId": "controlAuthenticationStatus",
        "responses": {
          "200": {
            "description": "Current Control session status.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ControlAuthenticationResponse" } } }
          }
        }
      }
    },
    "/api/control/v1/auth/login": {
      "post": {
        "operationId": "controlLogin",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ControlLoginRequest" } } }
        },
        "responses": {
          "200": {
            "description": "Authenticated Control session.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ControlAuthenticationResponse" } } }
          },
          "422": { "description": "Invalid secret or request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "503": { "description": "Control authentication is unavailable.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/control/v1/auth/logout": {
      "post": {
        "operationId": "controlLogout",
        "responses": { "204": { "description": "Control session ended." }, "401": { "description": "Unauthenticated.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } } }
      }
    },
    "/api/control/v1/auth/confirm-secret": {
      "post": {
        "operationId": "confirmControlSecret",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ControlLoginRequest" } } }
        },
        "responses": {
          "200": {
            "description": "The Control secret was confirmed for high-risk changes.",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ControlSecretConfirmationResponse" } } }
          },
          "401": { "description": "Unauthenticated.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "422": { "description": "Invalid secret or request.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/participant/v1/join": {
      "post": {
        "operationId": "participantJoin",
        "tags": ["Participant sessions"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantJoinRequest" } } } },
        "responses": { "201": { "$ref": "#/components/responses/ParticipantJoinResponse" }, "422": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/resume": {
      "post": {
        "operationId": "participantResume",
        "tags": ["Participant sessions"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantResumeRequest" } } } },
        "responses": { "200": { "$ref": "#/components/responses/ParticipantSessionResponse" }, "404": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/roster": {
      "get": {
        "operationId": "participantRoster",
        "tags": ["Participant sessions"],
        "responses": { "200": { "$ref": "#/components/responses/ParticipantRosterResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/player-groups": {
      "get": {
        "operationId": "participantPlayerGroups",
        "tags": ["Participant collaboration"],
        "responses": { "200": { "$ref": "#/components/responses/ParticipantPlayerGroupsResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/messages": {
      "get": {
        "operationId": "participantMessages",
        "tags": ["Participant collaboration"],
        "responses": { "200": { "$ref": "#/components/responses/ParticipantMessagesResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" } }
      },
      "post": {
        "operationId": "createParticipantMessage",
        "tags": ["Participant collaboration"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateParticipantMessageRequest" } } } },
        "responses": { "200": { "$ref": "#/components/responses/ParticipantMessageMutationResponse" }, "201": { "$ref": "#/components/responses/ParticipantMessageMutationResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" }, "422": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/polls": {
      "get": {
        "operationId": "participantPolls",
        "tags": ["Participant collaboration"],
        "responses": { "200": { "$ref": "#/components/responses/ParticipantPollsResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/polls/{poll}/vote": {
      "post": {
        "operationId": "voteParticipantPoll",
        "tags": ["Participant collaboration"],
        "parameters": [{ "$ref": "#/components/parameters/PollId" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VoteParticipantPollRequest" } } } },
        "responses": { "200": { "$ref": "#/components/responses/ParticipantPollMutationResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" }, "404": { "$ref": "#/components/responses/ErrorResponse" }, "422": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/rolls": {
      "get": {
        "operationId": "participantRolls",
        "tags": ["Participant collaboration"],
        "responses": { "200": { "$ref": "#/components/responses/ParticipantRollsResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" } }
      },
      "post": {
        "operationId": "createParticipantRoll",
        "tags": ["Participant collaboration"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateParticipantRollRequest" } } } },
        "responses": { "200": { "$ref": "#/components/responses/ParticipantRollMutationResponse" }, "201": { "$ref": "#/components/responses/ParticipantRollMutationResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" }, "422": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/roll-presets": {
      "get": {
        "operationId": "participantRollPresets",
        "tags": ["Participant collaboration"],
        "responses": { "200": { "$ref": "#/components/responses/ParticipantRollPresetsResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/claim": {
      "post": {
        "operationId": "claimParticipantCharacter",
        "tags": ["Participant sessions"],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantClaimRequest" } } } },
        "responses": { "201": { "$ref": "#/components/responses/ParticipantClaimResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" }, "422": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/npcs": {
      "get": {
        "operationId": "participantNpcs",
        "tags": ["Participant collaboration"],
        "responses": { "200": { "$ref": "#/components/responses/ParticipantNpcsResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/npcs/{npc}/notes": {
      "post": {
        "operationId": "createParticipantNpcNote",
        "tags": ["Participant collaboration"],
        "parameters": [{ "$ref": "#/components/parameters/NpcId" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateParticipantNpcNoteRequest" } } } },
        "responses": { "200": { "$ref": "#/components/responses/ParticipantNpcNoteMutationResponse" }, "201": { "$ref": "#/components/responses/ParticipantNpcNoteMutationResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" }, "404": { "$ref": "#/components/responses/ErrorResponse" }, "422": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/npc-notes/{note}": {
      "patch": {
        "operationId": "updateParticipantNpcNote",
        "tags": ["Participant collaboration"],
        "parameters": [{ "$ref": "#/components/parameters/NpcNoteId" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateParticipantNpcNoteRequest" } } } },
        "responses": { "200": { "$ref": "#/components/responses/ParticipantNpcNoteMutationResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" }, "404": { "$ref": "#/components/responses/ErrorResponse" }, "422": { "$ref": "#/components/responses/ErrorResponse" } }
      },
      "delete": {
        "operationId": "deleteParticipantNpcNote",
        "tags": ["Participant collaboration"],
        "parameters": [{ "$ref": "#/components/parameters/NpcNoteId" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CommandRequest" } } } },
        "responses": { "200": { "$ref": "#/components/responses/ParticipantNpcNoteMutationResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" }, "404": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/map": {
      "get": {
        "operationId": "participantCurrentMap",
        "tags": ["Participant maps"],
        "responses": { "200": { "$ref": "#/components/responses/ParticipantMapStateResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/map/assets/{asset}/read": {
      "get": {
        "operationId": "readParticipantMapAsset",
        "tags": ["Participant maps"],
        "parameters": [{ "$ref": "#/components/parameters/AssetId" }],
        "responses": { "200": { "$ref": "#/components/responses/SignedUrlResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "404": { "$ref": "#/components/responses/ErrorResponse" }, "422": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    },
    "/api/participant/v1/maps/{map}/progress": {
      "get": {
        "operationId": "participantMapProgress",
        "tags": ["Participant maps"],
        "parameters": [{ "$ref": "#/components/parameters/MapId" }],
        "responses": { "200": { "$ref": "#/components/responses/ParticipantMapProgressResponse" }, "401": { "$ref": "#/components/responses/ErrorResponse" }, "403": { "$ref": "#/components/responses/ErrorResponse" }, "404": { "$ref": "#/components/responses/ErrorResponse" } }
      }
    }
  },
  "components": {
    "parameters": {
      "PollId": { "name": "poll", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
      "NpcId": { "name": "npc", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
      "NpcNoteId": { "name": "note", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
      "MapId": { "name": "map", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } },
      "AssetId": { "name": "asset", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
    },
    "responses": {
      "ErrorResponse": { "description": "Request failed.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
      "ParticipantSessionResponse": { "description": "Resumed participant session.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantSessionResponse" } } } },
      "ParticipantJoinResponse": { "description": "New participant session and resume token.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantJoinResponse" } } } },
      "ParticipantRosterResponse": { "description": "Pinned campaign roster available to the participant.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantRosterResponse" } } } },
      "ParticipantPlayerGroupsResponse": { "description": "Groups visible to the current Player.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantPlayerGroupsResponse" } } } },
      "ParticipantMessagesResponse": { "description": "Messages visible to the current participant.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantMessagesResponse" } } } },
      "ParticipantMessageMutationResponse": { "description": "Created or replayed participant message.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantMessageMutationResponse" } } } },
      "ParticipantPollsResponse": { "description": "Polls visible to the current participant.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantPollsResponse" } } } },
      "ParticipantPollMutationResponse": { "description": "Updated or replayed participant poll vote.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantPollMutationResponse" } } } },
      "ParticipantRollsResponse": { "description": "Rolls visible to the current participant.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantRollsResponse" } } } },
      "ParticipantRollPresetsResponse": { "description": "Dice presets available to the current participant.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantRollPresetsResponse" } } } },
      "ParticipantRollMutationResponse": { "description": "Created or replayed roll.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantRollMutationResponse" } } } },
      "ParticipantClaimResponse": { "description": "Character claim created.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantClaimResponse" } } } },
      "ParticipantNpcsResponse": { "description": "NPCs revealed to the current participant.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantNpcsResponse" } } } },
      "ParticipantNpcNoteMutationResponse": { "description": "Created, changed, or deleted NPC note.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantNpcNoteMutationResponse" } } } },
      "ParticipantMapStateResponse": { "description": "Current Player map state and participant-safe snapshot.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantMapStateResponse" } } } },
      "ParticipantMapProgressResponse": { "description": "Participant-safe map progress snapshot.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ParticipantMapProgressResponse" } } } },
      "SignedUrlResponse": { "description": "Short-lived map asset read URL.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SignedUrlResponse" } } } }
    },
    "schemas": {
      "ControlAuthenticationResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["authenticated"],
            "properties": { "authenticated": { "type": "boolean" } }
          }
        }
      },
      "ControlLoginRequest": {
        "type": "object",
        "required": ["secret"],
        "properties": { "secret": { "type": "string", "minLength": 1, "maxLength": 4096 } }
      },
      "ControlSecretConfirmationResponse": {
        "type": "object",
        "required": ["data"],
        "properties": {
          "data": {
            "type": "object",
            "required": ["confirmed_until"],
            "properties": { "confirmed_until": { "type": "string", "format": "date-time" } }
          }
        }
      },
      "Error": {
        "type": "object",
        "required": ["message"],
        "properties": { "message": { "type": "string" }, "errors": { "type": "object", "additionalProperties": true } }
      },
      "ParticipantJoinRequest": {
        "type": "object", "required": ["player_code", "display_name", "role"],
        "properties": { "player_code": { "type": "string", "maxLength": 12 }, "display_name": { "type": "string", "maxLength": 120 }, "role": { "type": "string", "enum": ["player", "spectator"] } }
      },
      "ParticipantResumeRequest": {
        "type": "object", "required": ["resume_token"],
        "properties": { "resume_token": { "type": "string", "minLength": 64, "maxLength": 64 } }
      },
      "CommandRequest": {
        "type": "object", "required": ["command_id"],
        "properties": { "command_id": { "type": "string", "format": "uuid" } }
      },
      "CreateParticipantMessageRequest": {
        "allOf": [
          { "$ref": "#/components/schemas/CommandRequest" },
          { "type": "object", "required": ["target_type", "body"], "properties": { "target_type": { "type": "string", "enum": ["control", "player_group"] }, "session_player_group_id": { "type": ["string", "null"], "format": "uuid" }, "reply_to_session_message_id": { "type": ["string", "null"], "format": "uuid" }, "body": { "type": "string", "minLength": 1, "maxLength": 2000 } } }
        ]
      },
      "VoteParticipantPollRequest": {
        "allOf": [
          { "$ref": "#/components/schemas/CommandRequest" },
          { "type": "object", "required": ["option_ids"], "properties": { "option_ids": { "type": "array", "minItems": 1, "maxItems": 12, "items": { "type": "string", "format": "uuid" } } } }
        ]
      },
      "CreateParticipantRollRequest": {
        "allOf": [
          { "$ref": "#/components/schemas/CommandRequest" },
          { "type": "object", "properties": { "expression": { "type": ["string", "null"], "maxLength": 200 }, "dice_preset_id": { "type": ["string", "null"], "format": "uuid" }, "visibility": { "type": ["string", "null"], "enum": ["public", "private", null] } } }
        ]
      },
      "ParticipantClaimRequest": {
        "type": "object", "required": ["player_character_id"],
        "properties": { "player_character_id": { "type": "string", "format": "uuid" } }
      },
      "CreateParticipantNpcNoteRequest": {
        "allOf": [
          { "$ref": "#/components/schemas/CommandRequest" },
          { "type": "object", "required": ["body"], "properties": { "body": { "type": "string", "minLength": 1, "maxLength": 2000 } } }
        ]
      },
      "MutationMeta": {
        "type": "object", "required": ["replayed"], "properties": { "replayed": { "type": "boolean" } }
      },
      "ParticipantSession": {
        "type": "object", "required": ["id", "role", "display_name"],
        "properties": { "id": { "type": "string", "format": "uuid" }, "role": { "type": "string", "enum": ["player", "spectator"] }, "display_name": { "type": "string" } }
      },
      "ParticipantCharacter": {
        "type": "object", "required": ["id", "name", "pronouns", "public_description", "claimed", "claimed_by_me"],
        "properties": { "id": { "type": "string", "format": "uuid" }, "name": { "type": ["string", "null"] }, "pronouns": { "type": ["string", "null"] }, "public_description": { "type": ["string", "null"] }, "claimed": { "type": "boolean" }, "claimed_by_me": { "type": "boolean" } }
      },
      "ParticipantPlayerGroup": {
        "type": "object", "required": ["id", "name"],
        "properties": { "id": { "type": "string", "format": "uuid" }, "name": { "type": "string" } }
      },
      "ParticipantMessage": {
        "type": "object", "required": ["id", "sender_type", "sender_session_participant_id", "sender_name", "target_type", "target_session_participant_id", "session_player_group_id", "reply_to_session_message_id", "body", "created_at"],
        "properties": { "id": { "type": "string", "format": "uuid" }, "sender_type": { "type": "string", "enum": ["control", "participant"] }, "sender_session_participant_id": { "type": ["string", "null"], "format": "uuid" }, "sender_name": { "type": "string" }, "target_type": { "type": "string", "enum": ["control", "individual", "player_group", "all_players", "all_spectators", "all"] }, "target_session_participant_id": { "type": ["string", "null"], "format": "uuid" }, "session_player_group_id": { "type": ["string", "null"], "format": "uuid" }, "reply_to_session_message_id": { "type": ["string", "null"], "format": "uuid" }, "body": { "type": "string" }, "created_at": { "type": "string", "format": "date-time" } }
      },
      "ParticipantPollOption": {
        "type": "object", "required": ["id", "body", "votes"],
        "properties": { "id": { "type": "string", "format": "uuid" }, "body": { "type": "string" }, "votes": { "type": ["integer", "null"] } }
      },
      "ParticipantPoll": {
        "type": "object", "required": ["id", "question", "allows_multiple", "target_type", "target_session_participant_id", "session_player_group_id", "status", "result_visibility", "options", "my_option_ids", "closed_at", "created_at"],
        "properties": { "id": { "type": "string", "format": "uuid" }, "question": { "type": "string" }, "allows_multiple": { "type": "boolean" }, "target_type": { "type": "string" }, "target_session_participant_id": { "type": ["string", "null"], "format": "uuid" }, "session_player_group_id": { "type": ["string", "null"], "format": "uuid" }, "status": { "type": "string", "enum": ["open", "closed"] }, "result_visibility": { "type": "string", "enum": ["none", "live", "final"] }, "options": { "type": "array", "items": { "$ref": "#/components/schemas/ParticipantPollOption" } }, "my_option_ids": { "type": "array", "items": { "type": "string", "format": "uuid" } }, "closed_at": { "type": ["string", "null"], "format": "date-time" }, "created_at": { "type": "string", "format": "date-time" } }
      },
      "ParticipantRoll": {
        "type": "object", "required": ["id", "session_participant_id", "roller_name", "dice_preset_id", "dice_preset_name", "expression", "visibility", "total", "breakdown", "revealed_at", "created_at"],
        "properties": { "id": { "type": "string", "format": "uuid" }, "session_participant_id": { "type": "string", "format": "uuid" }, "roller_name": { "type": "string" }, "dice_preset_id": { "type": ["string", "null"], "format": "uuid" }, "dice_preset_name": { "type": ["string", "null"] }, "expression": { "type": "string" }, "visibility": { "type": "string", "enum": ["public", "private"] }, "total": { "type": "integer" }, "breakdown": { "type": "object", "additionalProperties": true }, "revealed_at": { "type": ["string", "null"], "format": "date-time" }, "created_at": { "type": "string", "format": "date-time" } }
      },
      "ParticipantRollPreset": {
        "type": "object", "required": ["id", "name", "expression", "default_visibility", "is_default"],
        "properties": { "id": { "type": "string", "format": "uuid" }, "name": { "type": "string" }, "expression": { "type": "string" }, "default_visibility": { "type": "string", "enum": ["public", "private"] }, "is_default": { "type": "boolean" } }
      },
      "ParticipantNpcNote": {
        "type": "object", "required": ["id", "npc_id", "author_type", "session_participant_id", "body", "created_at", "updated_at"],
        "properties": { "id": { "type": "string", "format": "uuid" }, "npc_id": { "type": "string", "format": "uuid" }, "author_type": { "type": "string", "enum": ["control", "participant"] }, "session_participant_id": { "type": ["string", "null"], "format": "uuid" }, "author_name": { "type": "string" }, "body": { "type": "string" }, "created_at": { "type": "string", "format": "date-time" }, "updated_at": { "type": "string", "format": "date-time" } }
      },
      "ParticipantNpc": {
        "type": "object", "required": ["id", "name", "pronouns", "public_description", "revealed_at", "notes"],
        "properties": { "id": { "type": "string", "format": "uuid" }, "name": { "type": ["string", "null"] }, "pronouns": { "type": ["string", "null"] }, "public_description": { "type": ["string", "null"] }, "revealed_at": { "type": ["string", "null"], "format": "date-time" }, "notes": { "type": "array", "items": { "$ref": "#/components/schemas/ParticipantNpcNote" } } }
