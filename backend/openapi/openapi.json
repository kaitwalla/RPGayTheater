      "ParticipantRollsResponse": { "type": "object", "required": ["data"], "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/ParticipantRoll" } } } },
      "ParticipantRollPresetsResponse": { "type": "object", "required": ["data"], "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/ParticipantRollPreset" } } } },
      "ParticipantRollMutationResponse": { "type": "object", "required": ["data", "meta"], "properties": { "data": { "$ref": "#/components/schemas/ParticipantRoll" }, "meta": { "$ref": "#/components/schemas/MutationMeta" } } },
      "ParticipantClaimResponse": { "type": "object", "required": ["data"], "properties": { "data": { "type": "object", "required": ["id", "player_character_id"], "properties": { "id": { "type": "string", "format": "uuid" }, "player_character_id": { "type": "string", "format": "uuid" } } } } },
      "ParticipantNpcsResponse": { "type": "object", "required": ["data"], "properties": { "data": { "type": "array", "items": { "$ref": "#/components/schemas/ParticipantNpc" } } } },
      "ParticipantNpcNoteMutationResponse": { "type": "object", "required": ["data", "meta"], "properties": { "data": { "$ref": "#/components/schemas/ParticipantNpcNote" }, "meta": { "$ref": "#/components/schemas/MutationMeta" } } },
      "ParticipantMapStateResponse": { "type": "object", "required": ["data"], "properties": { "data": { "type": "object", "required": ["state", "map", "progress"], "properties": { "state": { "$ref": "#/components/schemas/PlayerMapState" }, "map": { "anyOf": [{ "$ref": "#/components/schemas/ParticipantMap" }, { "type": "null" }] }, "progress": { "anyOf": [{ "$ref": "#/components/schemas/ParticipantMapProgress" }, { "type": "null" }] } } } } },
      "ParticipantMapProgressResponse": { "type": "object", "required": ["data"], "properties": { "data": { "$ref": "#/components/schemas/ParticipantMapProgress" } } },
      "SignedUrlResponse": { "type": "object", "required": ["data"], "properties": { "data": { "type": "object", "required": ["url"], "properties": { "url": { "type": "string", "format": "uri" } } } } }
