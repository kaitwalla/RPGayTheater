{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "check:types": "vue-tsc --noEmit",
        "format:check": "prettier --check resources/shared tests/frontend *.config.ts *.config.js package.json",
        "lint": "eslint --max-warnings=0 resources tests *.config.ts *.config.js",
        "check:dead-code": "knip",
        "check:duplication": "jscpd --config jscpd.json",
        "audit:dependencies": "npm audit --audit-level=high",
        "test:e2e": "playwright test",
        "test:frontend": "vitest run --coverage && node --test tests/frontend/**/*.test.mjs",
        "generate:api": "openapi-typescript openapi/openapi.json -o resources/shared/generated/api.ts",
        "check:api": "openapi-typescript openapi/openapi.json -o /tmp/rpgays-openapi.ts && cmp -s /tmp/rpgays-openapi.ts resources/shared/generated/api.ts"
    },
    "devDependencies": {
        "@axe-core/playwright": "4.10.2",
        "@eslint/js": "^9.39.1",
        "@playwright/test": "1.55.1",
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/vue": "^8.1.0",
        "@vitest/coverage-v8": "^4.1.10",
        "@vue/compiler-dom": "^3.5.40",
        "@vue/test-utils": "^2.4.11",
        "concurrently": "^9.0.1",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.6.1",
        "jscpd": "^4.0.5",
        "jsdom": "^29.1.1",
        "knip": "^5.71.1",
        "laravel-vite-plugin": "^3.1",
        "openapi-typescript": "^7.13.0",
        "prettier": "^3.6.2",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.48.0",
        "vite": "^8.0.0",
        "vitest": "^4.1.10",
        "vue-tsc": "^3.3.7"
    },
    "dependencies": {
        "@laravel/passkeys": "^0.2.0",
        "@vitejs/plugin-vue": "^6.0.8",
        "konva": "^10.3.0",
        "laravel-echo": "^2.4.0",
        "openapi-fetch": "^0.17.0",
        "pinia": "^3.0.4",
        "pusher-js": "^8.5.0",
        "vue": "^3.5.40",
        "vue-konva": "^3.4.0",
        "vue-router": "^4.6.4"
    },
    "overrides": {
        "@redocly/openapi-core": {
            "js-yaml": "4.3.0"
        }
    }
}
