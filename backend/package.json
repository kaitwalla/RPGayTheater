{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "check:types": "vue-tsc --noEmit",
        "test:e2e": "playwright test",
        "test:frontend": "vitest run && node --test tests/frontend/**/*.test.mjs",
        "generate:api": "openapi-typescript openapi/openapi.json -o resources/shared/generated/api.ts",
        "check:api": "openapi-typescript openapi/openapi.json -o /tmp/rpgays-openapi.ts && cmp -s /tmp/rpgays-openapi.ts resources/shared/generated/api.ts"
    },
    "devDependencies": {
        "@axe-core/playwright": "4.10.2",
        "@playwright/test": "1.54.1",
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/vue": "^8.1.0",
        "@vue/test-utils": "^2.4.11",
        "concurrently": "^9.0.1",
        "jsdom": "^29.1.1",
        "laravel-vite-plugin": "^3.1",
        "openapi-typescript": "^7.13.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.0",
        "vitest": "^4.1.10",
        "vue-tsc": "^3.3.7"
    },
    "dependencies": {
        "@laravel/passkeys": "^0.2.0",
        "@vitejs/plugin-vue": "^6.0.8",
        "konva": "^10.3.0",
        "laravel-echo": "^2.4.0",
        "openapi-fetch": "^0.17.0",
        "pinia": "^3.0.4",
        "pusher-js": "^8.5.0",
        "vue": "^3.5.40",
        "vue-konva": "^3.4.0",
        "vue-router": "^4.6.4"
    }
}
