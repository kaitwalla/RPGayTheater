APP_NAME="RPGays"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
CONTROL_SECRET=local-development-secret-change-before-production
CONTROL_USER_EMAIL=control@rpgays.invalid
CONTROL_USER_NAME=Control
CONTROL_SECRET_CONFIRMATION_SECONDS=900

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=json
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=rpgays
DB_USERNAME=rpgays
DB_PASSWORD=rpgays

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=rpgays
REVERB_APP_KEY=rpgays-local-key
REVERB_APP_SECRET=rpgays-local-secret-change-before-production
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_ALLOWED_ORIGINS=http://localhost:8000
REALTIME_MAX_EVENT_BYTES=9216
FILESYSTEM_DISK=s3
ASSET_DISK=s3
ASSET_SIGNED_URL_MINUTES=10
ASSET_PART_SIZE_BYTES=8388608
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=rpgays
AWS_ENDPOINT=http://minio:9000
# The public endpoint embedded in browser-facing presigned upload/read URLs.
# Set this to your HTTPS object-storage or CDN origin in production.
ASSET_PUBLIC_S3_ENDPOINT=http://localhost:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"
# Local/browser fallback values. Hosted Pusher production reads its public
# browser configuration from BROADCAST_CONNECTION and PUSHER_* at page render.
VITE_BROADCASTER=reverb
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
# VITE_PUSHER_APP_KEY=
# VITE_PUSHER_APP_CLUSTER=
